{
  "info": {
    "name": "Livros API",
    "description": "API REST para gerenciar biblioteca de livros",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Login",
      "request": {
        "method": "POST",
        "url": "http://localhost:3000/auth/login"
      }
    },
    {
      "name": "📖 Listar Livros",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/api/livros"
      }
    },
    {
      "name": "📖 Buscar por ID",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/api/livros/1"
      }
    },
    {
      "name": "📝 Criar Livro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:3000/api/livros"
      }
    },
    {
      "name": "✏️ Atualizar",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:3000/api/livros/1"
      }
    },
    {
      "name": "🗑️ Deletar",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "http://localhost:3000/api/livros/1"
      }
    },
    {
      "name": "👥 Autores",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/api/autores"
      }
    },
    {
      "name": "📊 Stats",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/api/stats"
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}